<?php
$filename = 'test.xml';
$reader = xml_parser_create();
xml_set_element_handler($reader, "startElement", "endElement");
xml_set_character_data_handler($reader, "characterData");
xml_parser_set_option($reader, XML_OPTION_SKIP_WHITE, 1);
xml_parse($reader, file_get_contents($filename)) or die(sprintf("XML Error: %s at line %d",
    xml_error_string(xml_get_error_code($reader)),
    xml_get_current_line_number($reader)));
xml_parser_free($reader);

function startElement($parser, $name, $attrs) {
  echo "Start element: $name\n";
}

function endElement($parser, $name) {
  echo "End element: $name\n";
}

function characterData($parser, $data) {
  echo "Character data: $data\n";
}
?>
